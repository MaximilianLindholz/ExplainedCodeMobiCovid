# 76
full4 <- subset(full4, full4$c_rate >0)
# Select relevant columns and define unit as calculated above
long <- full4 %>% dplyr::select('c_pseudonym','exacttime', 'IMS','c_val','c_rate', 'length','c_date_time_to')
long$rateunit <- "µg/kg/min"
