tablemeans <- cbind(tablemeans, (aggregate(data[, c("averagelengthofPT")], list(data$norepinephrine), mean, na.rm=T)))
tablemeans <- tablemeans[,c(1,2,3,4,5,7)]
write.csv(tablemeans, file = "means.csv")
# inbed vs out of bed
