data = data, factorVars = c("tod","frühmobi"), test = F)
print(tab2, showAllLevels = TRUE,formatOptions = list(big.mark = ","))
tab4Mat <- print(tab2,showAllLevels = TRUE, quote = FALSE, noSpaces = TRUE, printToggle = TRUE)
