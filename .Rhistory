library(lme4)
library(car)
options(contrasts=c(unordered="contr.sum", ordered="contr.poly"))
# mobilization with norepinephrine
long <- fread('/Users/maximilianlindholz/Final/during.csv')
# general patient data
data <- fread('/Users/maximilianlindholz/Final/baseinfo5.csv')
iv <- fread('/Users/maximilianlindholz/Final/norepiclean.csv')
#qc/classes
summary(data)
str(data)
data$geschlecht<-as.factor(data$geschlecht)
data$Fachrichtung<-as.factor(data$Fachrichtung)
str(data)
# number of mobilizations per day
pdcov <- perday~geschlecht+age+obes+admissionapache+admissionsofa+Elixhauser+dialyse+ecmo+highflow+intubated+maskedventilation+tracheostomie+meanAbsoluteRass+Fachrichtung+norepinephrine
model1 <- lm(pdcov, data = data)
summary(model1)
Anova(model1, type = 3)
confint(model1)
# modelfit
plot(model1)
summary(model2)
Anova(model2, type = 3)
# test model
plot(model2)
# early mobilization yes/no
earlymob_model <- glm(frühmobi~ geschlecht+age+obes+Elixhauser+dialyse+ecmo+highflow+intubated+maskedventilation+tracheostomie+admissionapache+admissionsofa+Fachrichtung+meanAbsoluteRass+norepinephrine, data = data, family = 'binomial')
summary(earlymob_model)
Anova(earlymob_model, type = 3)
exp(earlymob_model$coefficients)
exp(confint(earlymob_model))
# Calc in vs out of bed (Intensity)
long$outofbed <-0
long$outofbed[long$IMS>3]<-1
long$outofbed <- as.factor(long$outofbed)
inbed <- subset(long, long$outofbed==0)
outofbed <- subset(long, long$outofbed==1)
outofbed <- outofbed %>% group_by(c_pseudonym) %>% filter(c_rate == max(c_rate))
outofbed$out <-1
inbed <- inbed %>% group_by(c_pseudonym) %>% filter(c_rate == max(c_rate))
inbed$out <- 0
long <- rbind(inbed, outofbed)
long <- merge(long, data, by ="c_pseudonym")
outofbed_model <- glm(out ~geschlecht+age+obes+Elixhauser+dialyse+ecmo+highflow+intubated+maskedventilation+tracheostomie+admissionapache+admissionsofa+Fachrichtung+RASS+c_rate, data = long, family = 'binomial')
summary(outofbed_model)
Anova(outofbed_model)
exp(outofbed_model$coefficients)
exp(confint(outofbed_model))
1/0.013
rm(list = ls());gc()
library(data.table)
library(tidyverse)
library(lme4)
library(car)
options(contrasts=c(unordered="contr.sum", ordered="contr.poly"))
# mobilization with norepinephrine
long <- fread('/Users/maximilianlindholz/Final/during.csv')
# general patient data
data <- fread('/Users/maximilianlindholz/Final/baseinfo5.csv')
iv <- fread('/Users/maximilianlindholz/Final/norepiclean.csv')
#qc/classes
summary(data)
str(data)
data$geschlecht<-as.factor(data$geschlecht)
data$Fachrichtung<-as.factor(data$Fachrichtung)
str(data)
# number of mobilizations per day
pdcov <- perday~geschlecht+age+obes+admissionapache+admissionsofa+Elixhauser+dialyse+ecmo+highflow+intubated+maskedventilation+tracheostomie+meanAbsoluteRass+Fachrichtung+norepinephrine
model1 <- lm(pdcov, data = data)
summary(model1)
Anova(model1, type = 3)
confint(model1)
# modelfit
plot(model1)
summary(model2)
Anova(model2, type = 3)
# test model
plot(model2)
# early mobilization yes/no
earlymob_model <- glm(frühmobi~ geschlecht+age+obes+Elixhauser+dialyse+ecmo+highflow+intubated+maskedventilation+tracheostomie+admissionapache+admissionsofa+Fachrichtung+meanAbsoluteRass+norepinephrine, data = data, family = 'binomial')
summary(earlymob_model)
Anova(earlymob_model, type = 3)
exp(earlymob_model$coefficients)
exp(confint(earlymob_model))
# Calc in vs out of bed (Intensity)
long$outofbed <-0
long$outofbed[long$IMS>3]<-1
long$outofbed <- as.factor(long$outofbed)
long <- long %>% group_by(c_pseudonym) %>% filter(c_rate == median(c_rate))
View(long)
long <- merge(long, data, by ="c_pseudonym")
head(long)
outofbed_model <- glm(outofbed ~geschlecht+age+obes+Elixhauser+dialyse+ecmo+highflow+intubated+maskedventilation+tracheostomie+admissionapache+admissionsofa+Fachrichtung+RASS+c_rate, data = long, family = 'binomial')
summary(outofbed_model)
Anova(outofbed_model)
exp(outofbed_model$coefficients)
exp(confint(outofbed_model))
# Calc in vs out of bed (Intensity)
imsmodel <- glmer(outofbed ~RASS+c_rate+(1|c_pseudonym), data = long, family = 'binomial')
imsmodel <- glmer(outofbed ~geschlecht+age+obes+Elixhauser+dialyse+ecmo+highflow+intubated+maskedventilation+tracheostomie+admissionapache+admissionsofa+Fachrichtung+RASS+c_rate+(1|c_pseudonym), data = long, family = 'binomial')
summary(imsmodel)
Anova(imsmodel, type = 3)
ggplot(long, aes(x = out , y = c_rate, group = out, col = out)) +
geom_boxplot()+
ylab("Norepinephrine rate in mcg/kg/min")+
scale_color_manual(name="Type", labels=c("In bed","Out of bed"), values=c("red","blue"))+
theme_classic()
rm(list = ls());gc()
